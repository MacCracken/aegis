}

fn test_aegis_config_json_roundtrip() {
    test_group("aegis_config_json_roundtrip");
    var c = aegis_config_default();
    aegis_config_set_max_events(c, 7777);
    aegis_config_set_auto_release_timeout_secs(c, 1234);
    var json = aegis_config_to_json(c);
    var c2 = aegis_config_from_json(json);
    assert_neq(c2, 0, "non-null parse");
    assert_eq(aegis_config_scan_on_install(c2),        1,    "scan_on_install");
    assert_eq(aegis_config_max_events(c2),             7777, "max_events");
    assert_eq(aegis_config_auto_release_timeout_secs(c2), 1234, "auto_release_timeout_secs");
    return 0;
}

fn test_aegis_config_json_auto_release_none() {
    test_group("aegis_config_json_auto_release_none");
    var c = aegis_config_default();  # default: auto_release_timeout_secs = -1 (None)
    var json = aegis_config_to_json(c);
    # Output should serialize to JSON null, not -1
    assert_eq(str_contains(json, str_from("\"auto_release_timeout_secs\":null")), 1,
    "None serializes as null");
    var c2 = aegis_config_from_json(json);
    assert_eq(aegis_config_auto_release_timeout_secs(c2), AEGIS_AUTO_RELEASE_NONE,
    "null round-trips back to AEGIS_AUTO_RELEASE_NONE");
    return 0;
}

