    var json = scan_result_to_json(r);
    var r2 = scan_result_from_json(json);
    assert_neq(r2, 0, "non-null parse");
    assert_streq(str_data(scan_target(r2)), "agent:agent-z", "target");
    assert_eq(scan_type_of(r2),             ST_ON_EXECUTE,    "scan_type");
    assert_eq(scan_clean(r2),               0,                "clean=false");
    assert_eq(vec_len(scan_findings(r2)),   1,                "1 finding round-tripped");
