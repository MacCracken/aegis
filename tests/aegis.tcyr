fn test_security_event_json_with_metadata() {
    test_group("security_event_json_with_metadata");
    var ev = security_event_new(EV_DATABASE_INTEGRITY, "database", "test-agent", THREAT_INFO, "DDL");
    event_metadata_set(ev, "ddl_operation", str_from("CREATE TABLE"));
    event_metadata_set(ev, "ddl_object",    str_from("users"));
    var json = security_event_to_json(ev);
    var ev2 = security_event_from_json(json);
    assert_neq(ev2, 0, "non-null parse");
    var meta = event_metadata(ev2);
    assert_neq(meta, 0, "metadata map non-null");
    assert_eq(map_has(meta, "ddl_operation"), 1, "ddl_operation key present");
    assert_eq(map_has(meta, "ddl_object"),    1, "ddl_object key present");
    assert_streq(str_data(map_get(meta, "ddl_operation")), "CREATE TABLE", "ddl_operation value");
    assert_streq(str_data(map_get(meta, "ddl_object")),    "users",        "ddl_object value");
    return 0;
}

fn test_ring_buffer_basic() {
    test_group("ring_buffer_basic");
    var rb = aegis_ring_new(4);
    assert_eq(aegis_ring_cap(rb), 4, "cap");
    assert_eq(aegis_ring_len(rb), 0, "empty len");
    aegis_ring_push(rb, 100);
    aegis_ring_push(rb, 200);
    aegis_ring_push(rb, 300);
    assert_eq(aegis_ring_len(rb),     3,   "len after 3 pushes");
    assert_eq(aegis_ring_get(rb, 0),  100, "oldest is 100");
    assert_eq(aegis_ring_get(rb, 1),  200, "middle is 200");
    assert_eq(aegis_ring_get(rb, 2),  300, "newest is 300");
    assert_eq(aegis_ring_get(rb, 99), 0,   "out-of-range returns 0");
    return 0;
}

fn test_ring_buffer_overwrite_oldest() {
    test_group("ring_buffer_overwrite_oldest");
    var rb = aegis_ring_new(3);
    aegis_ring_push(rb, 1);
    aegis_ring_push(rb, 2);
    aegis_ring_push(rb, 3);
    aegis_ring_push(rb, 4);  # overwrites 1
    aegis_ring_push(rb, 5);  # overwrites 2
    assert_eq(aegis_ring_len(rb),    3, "stays at cap");
    assert_eq(aegis_ring_get(rb, 0), 3, "oldest is 3");
    assert_eq(aegis_ring_get(rb, 1), 4, "next is 4");
    assert_eq(aegis_ring_get(rb, 2), 5, "newest is 5");
    return 0;
}

fn test_ring_buffer_iteration_order_after_wrap() {
    test_group("ring_buffer_iteration_order_after_wrap");
    # cap=5, push 8 items — should retain the last 5 in order.
    var rb = aegis_ring_new(5);
    var i = 1;
    while (i <= 8) {
        aegis_ring_push(rb, i * 10);
        i = i + 1;
    }
    # Expected logical order: 40, 50, 60, 70, 80
    assert_eq(aegis_ring_len(rb),    5,  "len = cap after overflow");
    assert_eq(aegis_ring_get(rb, 0), 40, "oldest is 40 (after 1,2,3 dropped)");
    assert_eq(aegis_ring_get(rb, 4), 80, "newest is 80");
    return 0;
}

fn test_ring_buffer_cap_clamp() {
    test_group("ring_buffer_cap_clamp");
    # Defensive clamp: cap <= 0 becomes cap = 1.
    var rb = aegis_ring_new(0);
    assert_eq(aegis_ring_cap(rb), 1, "cap=0 clamped to 1");
    aegis_ring_push(rb, 42);
    aegis_ring_push(rb, 99);
    assert_eq(aegis_ring_len(rb),    1,  "len stays at 1");
    assert_eq(aegis_ring_get(rb, 0), 99, "newest survives");
    return 0;
}

