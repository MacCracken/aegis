fn test_aegis_stats_json_roundtrip() {
    test_group("aegis_stats_json_roundtrip");
    var d = aegis_new(aegis_config_default());
    aegis_report_event(d, security_event_new(EV_POLICY_VIOLATION, "t", 0, THREAT_LOW,    "a"));
    aegis_report_event(d, security_event_new(EV_POLICY_VIOLATION, "t", 0, THREAT_LOW,    "b"));
    aegis_report_event(d, security_event_new(EV_POLICY_VIOLATION, "t", 0, THREAT_MEDIUM, "c"));
    var s = aegis_stats(d);
    var json = aegis_stats_to_json(s);
    var s2 = aegis_stats_from_json(json);
    assert_neq(s2, 0, "non-null parse");
    assert_eq(stats_total_events(s2),                3, "total");
    assert_eq(stats_threat_count(s2, THREAT_LOW),    2, "low count round-trips");
    assert_eq(stats_threat_count(s2, THREAT_MEDIUM), 1, "medium count round-trips");
    assert_eq(stats_threat_count(s2, THREAT_INFO),   0, "info count round-trips as 0");
    return 0;
}

fn test_quarantine_entry_json_roundtrip() {
    test_group("quarantine_entry_json_roundtrip");
    var d = aegis_new(aegis_config_default());
