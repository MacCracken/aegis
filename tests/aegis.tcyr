# aegis test suite
#
# First-slice tests: enums + label round-trips + SecurityEvent construction.

include "src/lib.cyr"
include "src/firewall.cyr"

# Helper: assert that a rendered nftables Str* contains the given
# cstr substring. Wraps both sides as Str* and delegates to
# str_contains. Keeps the firewall tests' arrange/assert blocks
# tight at the call site.
fn _fw_assert_contains(rendered, needle_cstr, name) {
    assert(str_contains(rendered, str_from(needle_cstr)) == 1, name);
    return 0;
}

fn test_threat_level_labels() {
    test_group("threat_level_labels");
    assert_streq(threat_level_label(THREAT_CRITICAL), "CRITICAL", "CRITICAL label");
    assert_streq(threat_level_label(THREAT_HIGH),     "HIGH",     "HIGH label");
    assert_streq(threat_level_label(THREAT_MEDIUM),   "MEDIUM",   "MEDIUM label");
    assert_streq(threat_level_label(THREAT_LOW),      "LOW",      "LOW label");
    assert_streq(threat_level_label(THREAT_INFO),     "INFO",     "INFO label");
    return 0;
}

fn test_threat_level_ordering() {
    test_group("threat_level_ordering");
    # More severe = lower numeric value (matches rust-old's manual Ord).
    assert(THREAT_CRITICAL < THREAT_HIGH,   "CRITICAL < HIGH");
    assert(THREAT_HIGH     < THREAT_MEDIUM, "HIGH < MEDIUM");
    assert(THREAT_MEDIUM   < THREAT_LOW,    "MEDIUM < LOW");
    assert(THREAT_LOW      < THREAT_INFO,   "LOW < INFO");
    return 0;
}

fn test_event_type_labels() {
    test_group("event_type_labels");
    assert_streq(event_type_label(EV_INTEGRITY_VIOLATION),
    "integrity_violation", "integrity_violation label");
    assert_streq(event_type_label(EV_SANDBOX_ESCAPE),
    "sandbox_escape", "sandbox_escape label");
    assert_streq(event_type_label(EV_DATABASE_INTEGRITY),
    "database_integrity", "database_integrity label");
    assert_streq(event_type_label(EV_DATABASE_ACCESS_VIOLATION),
    "database_access_violation", "database_access_violation label");
    return 0;
}

fn test_security_event_new() {
    test_group("security_event_new");
    var e = security_event_new(EV_POLICY_VIOLATION, "test", 0, THREAT_LOW, "test event");
    assert_eq(event_kind(e),         EV_POLICY_VIOLATION, "kind round-trips");
    assert_eq(event_threat_level(e), THREAT_LOW,          "threat_level round-trips");
    assert_eq(event_resolved(e),     0,                   "starts unresolved");
    assert_eq(event_agent_id(e),     0,                   "agent_id None when not provided");
    assert_eq(event_metadata(e),     0,                   "metadata lazy (0 until first set)");
    assert_gt(str_len(event_id(e)),         0, "id is non-empty");
    assert_gt(event_timestamp(e),           0, "timestamp is set");
    assert_gt(str_len(event_source(e)),     0, "source is non-empty");
    assert_gt(str_len(event_description(e)), 0, "description is non-empty");
    return 0;
}

fn test_event_set_resolved() {
    test_group("event_set_resolved");
    var e = security_event_new(EV_POLICY_VIOLATION, "test", 0, THREAT_INFO, "test");
    assert_eq(event_resolved(e), 0, "starts unresolved");
    event_set_resolved(e, 1);
    assert_eq(event_resolved(e), 1, "resolved=1 after set");
    return 0;
}

fn test_event_ids_unique() {
    test_group("event_ids_unique");
    var e1 = security_event_new(EV_POLICY_VIOLATION, "test", 0, THREAT_LOW, "first");
    var e2 = security_event_new(EV_POLICY_VIOLATION, "test", 0, THREAT_LOW, "second");
    assert_eq(str_eq(event_id(e1), event_id(e2)), 0, "ids differ across constructions");
    return 0;
}

fn test_aegis_config_defaults() {
    test_group("aegis_config_defaults");
    var c = aegis_config_default();
    assert_eq(aegis_config_scan_on_install(c),             1,     "scan_on_install default true");
    assert_eq(aegis_config_scan_on_execute(c),             1,     "scan_on_execute default true");
    assert_eq(aegis_config_periodic_scan_interval_secs(c), 3600,  "periodic_scan_interval_secs 3600");
    assert_eq(aegis_config_quarantine_on_critical(c),      1,     "quarantine_on_critical true");
    assert_eq(aegis_config_quarantine_on_high(c),          1,     "quarantine_on_high true");
    assert_eq(aegis_config_max_events(c),                  10000, "max_events 10000");
    assert_eq(aegis_config_auto_release_timeout_secs(c),
    AEGIS_AUTO_RELEASE_NONE,
    "auto_release_timeout_secs None (-1)");
    return 0;
}

fn test_aegis_new() {
    test_group("aegis_new");
    var d = aegis_new(aegis_config_default());
    assert_eq(aegis_total_events(d),               0, "no events on construction");
    assert_eq(aegis_threat_count(d, THREAT_CRITICAL), 0, "no critical counted");
    assert_eq(aegis_threat_count(d, THREAT_INFO),     0, "no info counted");
    return 0;
}

fn test_aegis_report_event_basic() {
    test_group("aegis_report_event_basic");
    var d = aegis_new(aegis_config_default());
    var ev = security_event_new(EV_POLICY_VIOLATION, "test", 0, THREAT_LOW, "policy");
    aegis_report_event(d, ev);
    assert_eq(aegis_total_events(d),                1, "events len 1 after one report");
    assert_eq(aegis_threat_count(d, THREAT_LOW),    1, "low count 1");
    assert_eq(aegis_threat_count(d, THREAT_HIGH),   0, "high count untouched");
    return 0;
}

fn test_aegis_threat_counts_per_level() {
    test_group("aegis_threat_counts_per_level");
    var d = aegis_new(aegis_config_default());
    aegis_report_event(d, security_event_new(EV_POLICY_VIOLATION, "t", 0, THREAT_LOW,    "a"));
    aegis_report_event(d, security_event_new(EV_POLICY_VIOLATION, "t", 0, THREAT_LOW,    "b"));
    aegis_report_event(d, security_event_new(EV_POLICY_VIOLATION, "t", 0, THREAT_MEDIUM, "c"));
    assert_eq(aegis_threat_count(d, THREAT_LOW),      2, "low count 2");
    assert_eq(aegis_threat_count(d, THREAT_MEDIUM),   1, "medium count 1");
    assert_eq(aegis_threat_count(d, THREAT_CRITICAL), 0, "critical count 0");
    return 0;
}

fn test_aegis_recent_events() {
    test_group("aegis_recent_events");
    var d = aegis_new(aegis_config_default());
    var i = 0;
    while (i < 5) {
        aegis_report_event(d, security_event_new(EV_POLICY_VIOLATION, "t", 0, THREAT_INFO, "x"));
        i = i + 1;
    }
    assert_eq(vec_len(aegis_recent_events(d, 3)),  3, "recent(3) len 3");
    assert_eq(vec_len(aegis_recent_events(d, 10)), 5, "recent(10) capped at total");
    return 0;
}

fn test_aegis_events_for_agent() {
    test_group("aegis_events_for_agent");
    var d = aegis_new(aegis_config_default());
    aegis_report_event(d, security_event_new(EV_POLICY_VIOLATION, "t", "alice", THREAT_LOW,  "a1"));
    aegis_report_event(d, security_event_new(EV_POLICY_VIOLATION, "t", "bob",   THREAT_LOW,  "b1"));
    aegis_report_event(d, security_event_new(EV_POLICY_VIOLATION, "t", "alice", THREAT_INFO, "a2"));
    aegis_report_event(d, security_event_new(EV_POLICY_VIOLATION, "t", 0,       THREAT_INFO, "x")); # None agent
    assert_eq(vec_len(aegis_events_for_agent(d, "alice")), 2, "alice has 2 events");
    assert_eq(vec_len(aegis_events_for_agent(d, "bob")),   1, "bob has 1 event");
    return 0;
}

fn test_aegis_events_by_threat() {
    test_group("aegis_events_by_threat");
    var d = aegis_new(aegis_config_default());
    aegis_report_event(d, security_event_new(EV_POLICY_VIOLATION, "t", 0, THREAT_MEDIUM, "a"));
    aegis_report_event(d, security_event_new(EV_POLICY_VIOLATION, "t", 0, THREAT_LOW,    "b"));
    aegis_report_event(d, security_event_new(EV_POLICY_VIOLATION, "t", 0, THREAT_MEDIUM, "c"));
    assert_eq(vec_len(aegis_events_by_threat(d, THREAT_MEDIUM)), 2, "medium events 2");
    assert_eq(vec_len(aegis_events_by_threat(d, THREAT_LOW)),    1, "low events 1");
    assert_eq(vec_len(aegis_events_by_threat(d, THREAT_INFO)),   0, "info events 0");
    return 0;
}

fn test_aegis_unresolved_events_and_resolve() {
    test_group("aegis_unresolved_events_and_resolve");
    var d = aegis_new(aegis_config_default());
    var e1 = security_event_new(EV_POLICY_VIOLATION, "t", 0, THREAT_LOW, "a");
    aegis_report_event(d, e1);
    aegis_report_event(d, security_event_new(EV_POLICY_VIOLATION, "t", 0, THREAT_INFO, "b"));
    assert_eq(aegis_unresolved_count(d),                            2, "2 unresolved before");
    assert_eq(vec_len(aegis_unresolved_events(d)),                  2, "2 unresolved listed");
    assert_eq(aegis_resolve_event(d, str_data(event_id(e1))),       1, "resolve_event returns 1 on hit");
    assert_eq(aegis_resolve_event(d, "nope"),                       0, "resolve_event returns 0 on miss");
    assert_eq(aegis_unresolved_count(d),                            1, "1 unresolved after");
    return 0;
}

fn test_aegis_max_events_prunes_oldest() {
    test_group("aegis_max_events_prunes_oldest");
    var c = aegis_config_default();
    aegis_config_set_max_events(c, 5);
    var d = aegis_new(c);
    var i = 0;
    while (i < 8) {
        aegis_report_event(d, security_event_new(EV_POLICY_VIOLATION, "t", 0, THREAT_INFO, "x"));
        i = i + 1;
    }
    assert_eq(aegis_total_events(d), 5, "events capped at max_events");
    return 0;
}

fn test_quarantine_action_labels() {
    test_group("quarantine_action_labels");
    assert_streq(quarantine_action_label(QA_NONE),      "none",       "QA_NONE label");
    assert_streq(quarantine_action_label(QA_SUSPEND),   "suspend",    "QA_SUSPEND label");
    assert_streq(quarantine_action_label(QA_TERMINATE), "terminate",  "QA_TERMINATE label");
    assert_streq(quarantine_action_label(QA_ISOLATE),   "isolate",    "QA_ISOLATE label");
    assert_streq(quarantine_action_label(QA_RATELIMIT), "rate_limit", "QA_RATELIMIT label");
    return 0;
}

fn test_quarantine_and_release() {
    test_group("quarantine_and_release");
    var d = aegis_new(aegis_config_default());
    aegis_quarantine_agent(d, "agent-a", "test", THREAT_HIGH);
    assert_eq(aegis_is_quarantined(d, "agent-a"), 1, "is_quarantined=1 after quarantine");
    assert_eq(aegis_release_agent(d, "agent-a"),  1, "release returns 1 on hit");
    assert_eq(aegis_is_quarantined(d, "agent-a"), 0, "is_quarantined=0 after release");
    return 0;
}

fn test_release_non_quarantined() {
    test_group("release_non_quarantined");
    var d = aegis_new(aegis_config_default());
    assert_eq(aegis_release_agent(d, "nope"), 0, "release on empty map returns 0");
    aegis_quarantine_agent(d, "alice", "x", THREAT_HIGH);
    assert_eq(aegis_release_agent(d, "nope"), 0, "release of nonexistent returns 0");
    return 0;
}

fn test_get_quarantine_entry() {
    test_group("get_quarantine_entry");
    var d = aegis_new(aegis_config_default());
    aegis_quarantine_agent(d, "agent-b", "suspicious", THREAT_MEDIUM);
    var e = aegis_get_quarantine(d, "agent-b");
    assert_neq(e,                    0,             "entry is non-null");
    assert_eq(q_threat_level(e),     THREAT_MEDIUM, "threat_level Medium");
    assert_streq(str_data(q_reason(e)),   "suspicious", "reason round-trip");
    assert_streq(str_data(q_agent_id(e)), "agent-b",    "agent_id round-trip");
    return 0;
}

fn test_quarantined_agents_list() {
    test_group("quarantined_agents_list");
    var d = aegis_new(aegis_config_default());
    aegis_quarantine_agent(d, "a1", "r1", THREAT_HIGH);
    aegis_quarantine_agent(d, "a2", "r2", THREAT_CRITICAL);
    assert_eq(vec_len(aegis_quarantined_agents(d)), 2, "two quarantined");
    return 0;
}

fn test_quarantine_no_downgrade() {
    test_group("quarantine_no_downgrade");
    var d = aegis_new(aegis_config_default());
    aegis_quarantine_agent(d, "a1", "critical issue", THREAT_CRITICAL);
    var e = aegis_quarantine_agent(d, "a1", "lesser", THREAT_MEDIUM);
    assert_eq(q_threat_level(e), THREAT_CRITICAL, "stays Critical on lesser re-quarantine");
    return 0;
}

fn test_quarantine_escalates_and_appends_reason() {
    test_group("quarantine_escalates_and_appends_reason");
    var d = aegis_new(aegis_config_default());
    aegis_quarantine_agent(d, "a1", "first reason", THREAT_HIGH);
    var e = aegis_quarantine_agent(d, "a1", "second reason", THREAT_CRITICAL);
    assert_eq(q_threat_level(e), THREAT_CRITICAL, "escalates to Critical");
    var r = str_data(q_reason(e));
    assert_streq(r, "first reason; second reason", "reasons appended with separator");
    return 0;
}

fn test_auto_quarantine_on_critical() {
    test_group("auto_quarantine_on_critical");
    var d = aegis_new(aegis_config_default());
    var ev = security_event_new(EV_SANDBOX_ESCAPE, "test", "agent-1", THREAT_CRITICAL, "boom");
    var action = aegis_report_event(d, ev);
    assert_eq(action,                              QA_TERMINATE, "Critical → Terminate");
    assert_eq(aegis_is_quarantined(d, "agent-1"), 1,            "agent-1 quarantined");
    return 0;
}

fn test_auto_quarantine_on_high() {
    test_group("auto_quarantine_on_high");
    var d = aegis_new(aegis_config_default());
    var ev = security_event_new(EV_UNAUTHORIZED_ACCESS, "test", "agent-2", THREAT_HIGH, "x");
    var action = aegis_report_event(d, ev);
    assert_eq(action,                              QA_SUSPEND, "High → Suspend");
    assert_eq(aegis_is_quarantined(d, "agent-2"), 1,          "agent-2 quarantined");
    return 0;
}

fn test_no_quarantine_on_medium() {
    test_group("no_quarantine_on_medium");
    var d = aegis_new(aegis_config_default());
    var ev = security_event_new(EV_ANOMALOUS_BEHAVIOR, "test", "agent-3", THREAT_MEDIUM, "x");
    var action = aegis_report_event(d, ev);
    assert_eq(action,                              QA_NONE, "Medium → None");
    assert_eq(aegis_is_quarantined(d, "agent-3"), 0,       "agent-3 not quarantined");
    return 0;
}

fn test_no_quarantine_without_agent_id() {
    test_group("no_quarantine_without_agent_id");
    var d = aegis_new(aegis_config_default());
    var ev = security_event_new(EV_SANDBOX_ESCAPE, "test", 0, THREAT_CRITICAL, "boom");
    var action = aegis_report_event(d, ev);
    assert_eq(action, QA_NONE, "Critical w/o agent_id → None");
    assert_eq(aegis_total_events(d), 1, "event still recorded");
    return 0;
}

fn test_quarantine_links_events() {
    test_group("quarantine_links_events");
    var d = aegis_new(aegis_config_default());
    aegis_report_event(d, security_event_new(EV_MALICIOUS_PAYLOAD, "t", "agent-x", THREAT_CRITICAL, "first"));
    aegis_report_event(d, security_event_new(EV_SANDBOX_ESCAPE,    "t", "agent-x", THREAT_CRITICAL, "second"));
    var entry = aegis_get_quarantine(d, "agent-x");
    assert_eq(vec_len(q_events(entry)), 2, "two events linked to entry");
    return 0;
}

fn test_auto_release_timeout_expired() {
    test_group("auto_release_timeout_expired");
    var d = aegis_new(aegis_config_default());
    var entry = aegis_quarantine_agent(d, "agent-ar", "t", THREAT_MEDIUM);
    # Force expiry into the past.
    q_set_auto_release_at(entry, clock_epoch_secs() - 10);
    var released = aegis_check_auto_releases(d);
    assert_eq(vec_len(released),                    1, "one agent released");
    assert_eq(aegis_is_quarantined(d, "agent-ar"), 0, "no longer quarantined");
    return 0;
}

fn test_auto_release_timeout_not_expired() {
    test_group("auto_release_timeout_not_expired");
    var d = aegis_new(aegis_config_default());
    var entry = aegis_quarantine_agent(d, "agent-nr", "t", THREAT_MEDIUM);
    q_set_auto_release_at(entry, clock_epoch_secs() + 3600);
    var released = aegis_check_auto_releases(d);
    assert_eq(vec_len(released),                    0, "none released");
    assert_eq(aegis_is_quarantined(d, "agent-nr"), 1, "still quarantined");
    return 0;
}

fn test_auto_release_no_timeout_set() {
    test_group("auto_release_no_timeout_set");
    var d = aegis_new(aegis_config_default());  # default has timeout=None
    aegis_quarantine_agent(d, "agent-nt", "t", THREAT_MEDIUM);
    var released = aegis_check_auto_releases(d);
    assert_eq(vec_len(released),                    0, "none released w/ no timeout");
    assert_eq(aegis_is_quarantined(d, "agent-nt"), 1, "still quarantined");
    return 0;
}

# ================================================================
# Tempfile helpers — gap noted in cyrius-port-gaps.md ("missing
# functionality"). Inline here so tests can write/chmod/unlink
# real files for the world-writable / empty-binary scan paths.
# ================================================================
fn _tmp_write(path_cstr, content_cstr, mode) {
    var len = strlen(content_cstr);
    file_write_all(path_cstr, content_cstr, len);
    sys_chmod(path_cstr, mode);
    return 0;
}

fn _tmp_unlink(path_cstr) {
    sys_unlink(path_cstr);
    return 0;
}

fn _findings_have_category(findings, cat_cstr) {
    var n = vec_len(findings);
    var i = 0;
    while (i < n) {
        var f = vec_get(findings, i);
        if (streq(str_data(finding_category(f)), cat_cstr) == 1) { return 1; }
        i = i + 1;
    }
    return 0;
}

fn test_scan_type_labels() {
    test_group("scan_type_labels");
    assert_streq(scan_type_label(ST_ON_INSTALL), "on_install", "on_install label");
    assert_streq(scan_type_label(ST_ON_EXECUTE), "on_execute", "on_execute label");
    assert_streq(scan_type_label(ST_PERIODIC),   "periodic",   "periodic label");
    assert_streq(scan_type_label(ST_MANUAL),     "manual",     "manual label");
    return 0;
}

fn test_scan_agent_missing_binary() {
    test_group("scan_agent_missing_binary");
    var d = aegis_new(aegis_config_default());
    var r = aegis_scan_agent(d, "agent-m", "/nonexistent/binary");
    assert_eq(scan_clean(r),                                   0,            "not clean");
    assert_eq(vec_len(scan_findings(r)),                       1,            "one finding");
    assert_eq(_findings_have_category(scan_findings(r), "missing_binary"), 1, "missing_binary present");
    assert_eq(scan_type_of(r),                                 ST_ON_EXECUTE, "scan_type ON_EXECUTE");
    return 0;
}

fn test_scan_agent_disabled_by_config() {
    test_group("scan_agent_disabled_by_config");
    var c = aegis_config_default();
    aegis_config_set_scan_on_execute(c, 0);
    var d = aegis_new(c);
    var r = aegis_scan_agent(d, "agent-x", "/nonexistent/binary");
    assert_eq(scan_clean(r),             1, "disabled scan returns clean");
    assert_eq(vec_len(scan_findings(r)), 0, "no findings when disabled");
    return 0;
}

fn test_scan_agent_empty_binary() {
    test_group("scan_agent_empty_binary");
    var path = "/tmp/aegis_empty_test";
    _tmp_unlink(path);
    _tmp_write(path, "", 0x1A4);  # 0o644
    var d = aegis_new(aegis_config_default());
    var r = aegis_scan_agent(d, "agent-e", path);
    assert_eq(scan_clean(r),                                   0,            "not clean");
    assert_eq(_findings_have_category(scan_findings(r), "empty_binary"), 1,  "empty_binary present");
    _tmp_unlink(path);
    return 0;
}

fn test_scan_agent_world_writable() {
    test_group("scan_agent_world_writable");
    var path = "/tmp/aegis_ww_test";
    _tmp_unlink(path);
    _tmp_write(path, "data", 0x1B6);  # 0o666
    var d = aegis_new(aegis_config_default());
    var r = aegis_scan_agent(d, "agent-w", path);
    assert_eq(scan_clean(r),                                     0,           "not clean");
    assert_eq(_findings_have_category(scan_findings(r), "world_writable"), 1, "world_writable present");
    _tmp_unlink(path);
    return 0;
}

fn test_scan_agent_clean_file() {
    test_group("scan_agent_clean_file");
    var path = "/tmp/aegis_clean_test";
    _tmp_unlink(path);
    _tmp_write(path, "binary-content", 0x1A4);  # 0o644
    var d = aegis_new(aegis_config_default());
    var r = aegis_scan_agent(d, "agent-c", path);
    assert_eq(scan_clean(r),             1, "clean file scans clean");
    assert_eq(vec_len(scan_findings(r)), 0, "no findings");
    _tmp_unlink(path);
    return 0;
}

fn test_scan_package_missing() {
    test_group("scan_package_missing");
    var d = aegis_new(aegis_config_default());
    var r = aegis_scan_package(d, "/nonexistent/pkg.ark");
    assert_eq(scan_clean(r),                                    0,            "not clean");
    assert_eq(_findings_have_category(scan_findings(r), "missing_package"), 1, "missing_package present");
    assert_eq(scan_type_of(r),                                  ST_ON_INSTALL, "scan_type ON_INSTALL");
    return 0;
}

