    aegis_report_event(d, security_event_new(EV_MALICIOUS_PAYLOAD, "t", "agent-q", THREAT_CRITICAL, "boom2"));
    var q = aegis_get_quarantine(d, "agent-q");
    var json = quarantine_entry_to_json(q);
    var q2 = quarantine_entry_from_json(json);
    assert_neq(q2, 0, "non-null parse");
    assert_streq(str_data(q_agent_id(q2)), "agent-q",         "agent_id");
    assert_eq(q_threat_level(q2),          THREAT_CRITICAL,   "threat_level");
    assert_eq(vec_len(q_events(q2)),       2,                 "2 events linked");
    return 0;
}

fn test_quarantine_entry_json_auto_release_none() {
    test_group("quarantine_entry_json_auto_release_none");
