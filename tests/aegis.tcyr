# ================================================================
# Firewall builders (nein integration). Mirrors the 6 #[cfg(test)]
# cases in docs/reference/firewall.rs.ref so the cyrius port stays
# wire-compatible with the frozen rust spec.
# ================================================================

fn test_firewall_isolate_renders() {
    test_group("firewall_isolate_renders");
    var fw = aegis_isolate_agent("agent-1", "10.100.0.2");
    var rendered = aegis_firewall_render(fw);
    _fw_assert_contains(rendered, "table inet aegis_iso_agent-1", "table header");
    _fw_assert_contains(rendered, "ip daddr 10.100.0.2",          "input drops daddr");
    _fw_assert_contains(rendered, "ip saddr 10.100.0.2",          "output drops saddr");
    _fw_assert_contains(rendered, "drop",                         "drop verdict present");
    _fw_assert_contains(rendered, "aegis isolate agent-1",        "rule comment");
    return 0;
}

fn test_firewall_isolate_validates() {
    test_group("firewall_isolate_validates");
    var fw = aegis_isolate_agent("agent-1", "10.100.0.2");
    assert_eq(aegis_firewall_validate(fw), 0, "isolate firewall validates");
    return 0;
}

fn test_firewall_rate_limit_renders() {
    test_group("firewall_rate_limit_renders");
    var fw = aegis_rate_limit_agent("agent-1", "10.100.0.2", 100);
    var rendered = aegis_firewall_render(fw);
    _fw_assert_contains(rendered, "table inet aegis_rl_agent-1",            "table header");
    _fw_assert_contains(rendered, "limit rate 100/second burst 200 packets", "rate limit clause");
    _fw_assert_contains(rendered, "aegis rate-limit agent-1",                "accept rule comment");
    _fw_assert_contains(rendered, "aegis rate-limit drop agent-1",           "drop rule comment");
    return 0;
}

fn test_firewall_rate_limit_validates() {
    test_group("firewall_rate_limit_validates");
    var fw = aegis_rate_limit_agent("agent-1", "10.100.0.2", 50);
    assert_eq(aegis_firewall_validate(fw), 0, "rate-limit firewall validates");
    return 0;
}

fn test_firewall_hardened_host_renders() {
    test_group("firewall_hardened_host_renders");
    var fw = aegis_hardened_host();
    var rendered = aegis_firewall_render(fw);
    _fw_assert_contains(rendered, "table inet aegis_host",            "table header");
    _fw_assert_contains(rendered, "policy drop",                      "default drop policy");
    _fw_assert_contains(rendered, "ct state { established, related }", "established/related");
    _fw_assert_contains(rendered, "dport 22",                         "SSH port");
    _fw_assert_contains(rendered, "icmp type echo-request",           "ping rule");
    _fw_assert_contains(rendered, "loopback",                         "loopback comment");
    return 0;
}

fn test_firewall_hardened_host_validates() {
    test_group("firewall_hardened_host_validates");
    var fw = aegis_hardened_host();
    assert_eq(aegis_firewall_validate(fw), 0, "hardened-host firewall validates");
    return 0;
}

# ================================================================
# 0.9.3 P(-1) hardening tests — see docs/audit/2026-05-10-audit.md.
# Each test maps to a finding (F-1..F-5, F-8); F-2 + F-3 share the
# firewall-builder validators.
# ================================================================

# F-1: max_events clamp on JSON deserialization (and the setter).
fn test_p1_max_events_clamped() {
    test_group("p1_max_events_clamped");
    # Above hard cap → clamped to AEGIS_MAX_EVENTS_HARD_CAP.
    # First confirm parsing returns non-null for a tiny valid input.
    var c0 = aegis_config_from_json(str_from("{\"max_events\":42}"));
    assert_neq(c0, 0, "tiny config parse returns non-null");
    assert_eq(aegis_config_max_events(c0), 42,
    "small max_events round-trips");
    # Above hard cap (1M) → clamped.
    var c = aegis_config_from_json(str_from("{\"max_events\":5000000}"));
    assert_neq(c, 0, "above-cap config parse returns non-null");
    assert_eq(aegis_config_max_events(c), AEGIS_MAX_EVENTS_HARD_CAP,
    "above-cap max_events clamped to hard cap");
    # Negative or zero → default (10000).
    var c2 = aegis_config_from_json(str_from("{\"max_events\":-1}"));
    assert_eq(aegis_config_max_events(c2), 10000,
    "negative max_events → default");
    # Setter clamp (defense-in-depth).
    var c3 = aegis_config_default();
    aegis_config_set_max_events(c3, 5000000);
    assert_eq(aegis_config_max_events(c3), AEGIS_MAX_EVENTS_HARD_CAP,
    "setter clamp also fires");
    return 0;
}

# F-4: auto_release_timeout_secs — only -1 sentinel or [0, hard cap].
fn test_p1_auto_release_timeout_clamped() {
    test_group("p1_auto_release_timeout_clamped");
    # Negative non-sentinel → AEGIS_AUTO_RELEASE_NONE (default).
    var c = aegis_config_from_json(str_from("{\"auto_release_timeout_secs\":-86400}"));
    assert_eq(aegis_config_auto_release_timeout_secs(c), AEGIS_AUTO_RELEASE_NONE,
    "negative non-sentinel timeout → AUTO_RELEASE_NONE");
    # -1 sentinel preserved.
    var c2 = aegis_config_from_json(str_from("{\"auto_release_timeout_secs\":-1}"));
    assert_eq(aegis_config_auto_release_timeout_secs(c2), AEGIS_AUTO_RELEASE_NONE,
    "-1 sentinel preserved");
    # Above hard cap → clamped.
    var c3 = aegis_config_from_json(str_from("{\"auto_release_timeout_secs\":50000000}"));
    assert_eq(aegis_config_auto_release_timeout_secs(c3), AEGIS_TIMEOUT_HARD_CAP,
    "huge timeout clamped to TIMEOUT_HARD_CAP");
    return 0;
}

# F-5: periodic_scan_interval_secs — [0, hard cap].
fn test_p1_periodic_interval_clamped() {
    test_group("p1_periodic_interval_clamped");
    var c = aegis_config_from_json(str_from("{\"periodic_scan_interval_secs\":-1}"));
    assert_eq(aegis_config_periodic_scan_interval_secs(c), 0,
    "negative interval → 0");
    var c2 = aegis_config_from_json(str_from("{\"periodic_scan_interval_secs\":50000000}"));
    assert_eq(aegis_config_periodic_scan_interval_secs(c2), AEGIS_TIMEOUT_HARD_CAP,
    "huge interval clamped to TIMEOUT_HARD_CAP");
    return 0;
}

# F-2: firewall builders reject bad agent_id (nftables identifier injection).
fn test_p1_firewall_rejects_bad_agent_id() {
    test_group("p1_firewall_rejects_bad_agent_id");
    # Newline injection (iptables-save comment write-primitive class).
    assert_eq(aegis_isolate_agent("bad\nname", "10.0.0.1"), 0,
    "agent_id with newline rejected");
    # Semicolon (token break).
    assert_eq(aegis_isolate_agent("bad;drop", "10.0.0.1"), 0,
    "agent_id with semicolon rejected");
    # Empty.
    assert_eq(aegis_isolate_agent("", "10.0.0.1"), 0,
    "empty agent_id rejected");
    # Over-length (55 chars exceeds 54 cap).
    assert_eq(aegis_isolate_agent("a234567890123456789012345678901234567890123456789012345", "10.0.0.1"), 0,
    "over-length agent_id rejected");
    # Brace.
    assert_eq(aegis_rate_limit_agent("agent{}", "10.0.0.1", 100), 0,
    "agent_id with brace rejected (rate-limit path)");
    return 0;
}

# F-3: firewall builders reject bad agent_addr (match-value injection).
fn test_p1_firewall_rejects_bad_agent_addr() {
    test_group("p1_firewall_rejects_bad_agent_addr");
    # Newline injection.
    assert_eq(aegis_isolate_agent("agent-1", "10.0.0.1\ndrop"), 0,
    "agent_addr with newline rejected");
    # Space.
    assert_eq(aegis_isolate_agent("agent-1", "10.0.0.1 drop"), 0,
    "agent_addr with space rejected");
    # Empty.
    assert_eq(aegis_isolate_agent("agent-1", ""), 0,
    "empty agent_addr rejected");
    # rate_limit also enforces pps > 0.
    assert_eq(aegis_rate_limit_agent("agent-1", "10.0.0.1", 0), 0,
    "rate_limit with pps=0 rejected");
    assert_eq(aegis_rate_limit_agent("agent-1", "10.0.0.1", 0 - 1), 0,
    "rate_limit with negative pps rejected");
    return 0;
}

# F-2/F-3: confirm valid input still produces non-zero firewall (regression
# guard for the validator swallowing legitimate input).
fn test_p1_firewall_accepts_good_input() {
    test_group("p1_firewall_accepts_good_input");
    assert_neq(aegis_isolate_agent("agent-1", "10.0.0.1"), 0,
    "valid IPv4 isolate accepted");
    assert_neq(aegis_isolate_agent("a.b_c-1", "10.0.0.1/24"), 0,
    "valid mixed-id + CIDR accepted");
    assert_neq(aegis_isolate_agent("agent-1", "fe80::1"), 0,
    "valid IPv6 accepted");
    assert_neq(aegis_isolate_agent("agent-1", "fe80::1/128"), 0,
    "valid IPv6/128 accepted");
    assert_neq(aegis_rate_limit_agent("agent-1", "10.0.0.1", 100), 0,
    "valid rate_limit accepted");
    return 0;
}

# F-8: JSON input-length cap at the aegis deserialization seams.
fn test_p1_json_oversize_rejected() {
    test_group("p1_json_oversize_rejected");
    # Build a string longer than AEGIS_JSON_MAX_BYTES (256 KB).
    # Use vec_push of a single byte 300_000 times — bigger than the cap.
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"id\":\"");
    var pad = str_builder_new();
    var i = 0;
    while (i < 300000) {
        str_builder_add_cstr(pad, "x");
        i = i + 1;
    }
    var pad_str = str_builder_build(pad);
    str_builder_add(sb, pad_str);
    str_builder_add_cstr(sb, "\"}");
    var huge = str_builder_build(sb);
    # Each of the 8 record parsers should reject without crashing.
    assert_eq(security_event_from_json(str_data(huge)), 0,
    "oversize JSON rejected by security_event_from_json");
    assert_eq(quarantine_entry_from_json(str_data(huge)), 0,
    "oversize JSON rejected by quarantine_entry_from_json");
    assert_eq(aegis_config_from_json(str_data(huge)), 0,
    "oversize JSON rejected by aegis_config_from_json");
    return 0;
}

# ================================================================
# 0.9.4 P(-1) F-7 — quarantine-path agent_id whitelist enforcement.
# Categorically blocks Unicode confusables / case variants /
# zero-width inserts (CVE-2024-43093 family) since none of those
# bytes are in the [a-zA-Z0-9_.-] whitelist.
# ================================================================

fn test_p1_quarantine_rejects_bad_agent_id() {
    test_group("p1_quarantine_rejects_bad_agent_id");
    var d = aegis_new(aegis_config_default());
    # Newline injection.
    assert_eq(aegis_quarantine_agent(d, "bad\nname", "x", THREAT_HIGH), 0,
    "agent_id with newline rejected");
    # Empty.
    assert_eq(aegis_quarantine_agent(d, "", "x", THREAT_HIGH), 0,
    "empty agent_id rejected");
    # Slash (path-traversal flavor).
    assert_eq(aegis_quarantine_agent(d, "../etc/passwd", "x", THREAT_HIGH), 0,
    "agent_id with slash rejected");
    # Quote.
    assert_eq(aegis_quarantine_agent(d, "agent\"x", "x", THREAT_HIGH), 0,
    "agent_id with quote rejected");
    return 0;
}

fn test_p1_quarantine_release_rejects_bad() {
    test_group("p1_quarantine_release_rejects_bad");
    var d = aegis_new(aegis_config_default());
    aegis_quarantine_agent(d, "alice", "x", THREAT_HIGH);
    # Confirm baseline: alice is quarantined.
    assert_eq(aegis_is_quarantined(d, "alice"), 1, "alice quarantined");
    # Release with bad id should be rejected, alice still quarantined.
    assert_eq(aegis_release_agent(d, "alice\n"), 0,
    "release with newline rejected");
    assert_eq(aegis_is_quarantined(d, "alice"), 1,
    "alice still quarantined after bad release");
    # Valid release works.
    assert_eq(aegis_release_agent(d, "alice"), 1, "valid release succeeds");
    assert_eq(aegis_is_quarantined(d, "alice"), 0, "alice released");
    return 0;
}

fn test_p1_quarantine_is_get_reject_bad() {
    test_group("p1_quarantine_is_get_reject_bad");
    var d = aegis_new(aegis_config_default());
    aegis_quarantine_agent(d, "alice", "x", THREAT_HIGH);
    assert_eq(aegis_is_quarantined(d, "alice;drop"), 0,
    "is_quarantined rejects semicolon");
    assert_eq(aegis_get_quarantine(d, "alice;drop"), 0,
    "get_quarantine rejects semicolon");
    # Empty also rejected.
    assert_eq(aegis_is_quarantined(d, ""), 0, "is_quarantined rejects empty");
    assert_eq(aegis_get_quarantine(d, ""), 0, "get_quarantine rejects empty");
    return 0;
}

# security_event_new accepts null/empty (anonymous events) but strips
# non-empty bad agent_ids — the event is still recorded with aid=0.
# Silently dropping events would mask attack attempts.
fn test_p1_security_event_strips_bad_agent_id() {
    test_group("p1_security_event_strips_bad_agent_id");
    var ev = security_event_new(EV_SANDBOX_ESCAPE, "src", "bad\nid",
    THREAT_CRITICAL, "boom");
    assert_neq(ev, 0, "event still constructed");
    assert_eq(event_agent_id(ev), 0, "bad agent_id stripped to null");
    # Auto-quarantine path then sees no agent_id → no quarantine fires.
    var d = aegis_new(aegis_config_default());
    var action = aegis_report_event(d, ev);
    assert_eq(action, QA_NONE,
    "Critical event with stripped agent_id → no auto-quarantine");
    assert_eq(aegis_total_events(d), 1, "event still recorded");
    return 0;
}

# Regression guard — valid input still accepted on quarantine path.
fn test_p1_quarantine_accepts_good_input() {
    test_group("p1_quarantine_accepts_good_input");
    var d = aegis_new(aegis_config_default());
    var e = aegis_quarantine_agent(d, "agent-1", "x", THREAT_HIGH);
    assert_neq(e, 0, "valid agent_id quarantine succeeds");
    var e2 = aegis_quarantine_agent(d, "Agent.X_2", "x", THREAT_HIGH);
    assert_neq(e2, 0, "valid mixed-id accepted");
    return 0;
}

var exit_code = main();
syscall(60, exit_code);
