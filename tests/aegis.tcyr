}

fn test_security_event_json_roundtrip() {
    test_group("security_event_json_roundtrip");
    var ev = security_event_new(EV_SANDBOX_ESCAPE, "integrity", "agent-x", THREAT_CRITICAL, "boom");
    var json = security_event_to_json(ev);
    # Spot-check: PascalCase event_type label
    assert_eq(str_contains(json, str_from("\"event_type\":\"SandboxEscape\"")), 1,
    "event_type renders as PascalCase variant");
    var ev2 = security_event_from_json(json);
    assert_neq(ev2, 0, "non-null parse");
    assert_eq(event_kind(ev2),                           EV_SANDBOX_ESCAPE, "kind");
    assert_eq(event_threat_level(ev2),                   THREAT_CRITICAL,    "threat_level");
    assert_streq(str_data(event_agent_id(ev2)),          "agent-x",          "agent_id");
    assert_streq(str_data(event_source(ev2)),            "integrity",        "source");
    assert_streq(str_data(event_description(ev2)),       "boom",             "description");
    assert_eq(event_resolved(ev2),                       0,                  "resolved=false");
    return 0;
}

