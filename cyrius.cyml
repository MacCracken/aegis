[package]
name = "aegis"
version = "${file:VERSION}"
description = "aegis — security daemon for AGNOS"
license = "GPL-3.0-only"
language = "cyrius"
cyrius = "5.10.0"

[build]
entry = "src/main.cyr"
output = "aegis"

[deps]
stdlib = ["string", "fmt", "alloc", "vec", "str", "syscalls", "io", "args", "assert", "tagged", "chrono", "hashmap", "bench", "fnptr", "sakshi"]

[deps.agnostik]
git = "https://github.com/MacCracken/agnostik.git"
path = "../agnostik"
tag = "1.0.0"
modules = ["src/types.cyr"]
